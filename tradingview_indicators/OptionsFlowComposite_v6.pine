// =============================================================================
// OPTIONS FLOW COMPOSITE INDICATOR v6.0
// =============================================================================
// A research-backed composite indicator combining:
// - Volume Analysis (proxy for options flow intensity)  [Weight: 35%]
// - Volatility Contraction Pattern detection              [Weight: 30%]
// - Momentum Composite (RSI + MACD)                       [Weight: 15%]
// - Trend Alignment (EMA Structure)                       [Weight: 15%]
// - Mean Reversion (Bollinger Band Position)              [Weight: 5%]
//
// Research Basis:
// - PCA analysis of options sentiment (PMC Study)
// - VCP methodology (Mark Minervini)
// - Put/Call ratio contrarian signals
// - Short interest + options flow dynamics
// =============================================================================

//@version=6
indicator("Options Flow Composite v6.0", shorttitle="OFC v6", overlay=false, 
     timeframe="", timeframe_gaps=true)

// =============================================================================
// INPUTS
// =============================================================================
group_weights = "Component Weights (Must Sum to 1.0)"
group_atr = "ATR & Volatility Settings"
group_bb = "Bollinger Band Settings"
group_rsi = "RSI Settings"
group_macd = "MACD Settings"
group_ema = "EMA Trend Settings"
group_signals = "Signal Thresholds"
group_viz = "Visualization"

// Optimized weights from backtesting 14 tickers (NVDA, SMH, SOXX, MRVL, VRT, BE, GDX, SLV, ALAB, CRDO, WDC, SNDK, STX, MU)
weight_vol = input.float(0.35, "Volume/Flow Intensity", minval=0, maxval=1, step=0.05, group=group_weights)
weight_vcp = input.float(0.30, "Volatility Contraction", minval=0, maxval=1, step=0.05, group=group_weights)
weight_mom = input.float(0.15, "Momentum (RSI+MACD)", minval=0, maxval=1, step=0.05, group=group_weights)
weight_trd = input.float(0.15, "Trend Alignment", minval=0, maxval=1, step=0.05, group=group_weights)
weight_mr  = input.float(0.05, "Mean Reversion", minval=0, maxval=1, step=0.05, group=group_weights)

// ATR Settings
atr_len = input.int(14, "ATR Length", minval=1, group=group_atr)
atr_mult_stop = input.float(2.0, "ATR Stop Loss Multiplier", minval=0.5, step=0.5, group=group_atr)
atr_mult_tp = input.float(4.0, "ATR Take Profit Multiplier", minval=1.0, step=0.5, group=group_atr)

// Bollinger Band Settings
bb_len = input.int(20, "BB Length", minval=5, group=group_bb)
bb_mult = input.float(2.0, "BB StdDev Multiplier", minval=0.5, step=0.5, group=group_bb)
bb_squeeze_pct = input.float(85.0, "Squeeze Threshold (%)", minval=50, maxval=100, group=group_bb)

// RSI Settings
rsi_len = input.int(14, "RSI Length", minval=2, group=group_rsi)
rsi_overbought = input.int(75, "RSI Overbought", minval=50, maxval=100, group=group_rsi)
rsi_oversold = input.int(25, "RSI Oversold", minval=0, maxval=50, group=group_rsi)

// MACD Settings
macd_fast = input.int(12, "MACD Fast", minval=2, group=group_macd)
macd_slow = input.int(26, "MACD Slow", minval=5, group=group_macd)
macd_sig = input.int(9, "MACD Signal", minval=2, group=group_macd)

// EMA Settings
ema_fast_len = input.int(20, "Fast EMA", minval=5, group=group_ema)
ema_mid_len = input.int(50, "Medium EMA", minval=10, group=group_ema)
ema_slow_len = input.int(200, "Slow EMA", minval=20, group=group_ema)

// Signal Thresholds
bull_thresh = input.int(65, "Bullish Threshold", minval=50, maxval=100, group=group_signals)
bear_thresh = input.int(35, "Bearish Threshold", minval=0, maxval=50, group=group_signals)

// Visualization
show_scores = input.bool(true, "Show Component Scores", group=group_viz)
show_early = input.bool(true, "Show Early Entry/Exit Markers", group=group_viz)
show_bg = input.bool(true, "Color Background by Signal", group=group_viz)

// =============================================================================
// CALCULATIONS
// =============================================================================

// --- Price Data ---
close_price = close
high_price = high
low_price = low
vol = volume

// --- 1. ATR & Volatility ---
atr_val = ta.atr(atr_len)
atr_pct = atr_val / close_price * 100

// --- 2. Bollinger Bands ---
bb_basis = ta.sma(close_price, bb_len)
bb_dev = bb_mult * ta.stdev(close_price, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis * 100
bb_width_ma = ta.sma(bb_width, bb_len)
bb_pct = (close_price - bb_lower) / (bb_upper - bb_lower + 1e-10)

// Bollinger Squeeze Detection
bb_squeeze = bb_width < bb_width_ma * bb_squeeze_pct / 100

// --- 3. Keltner Channels (for squeeze confirmation) ---
kc_basis = ta.ema(close_price, bb_len)
kc_upper = kc_basis + 1.5 * atr_val
kc_lower = kc_basis - 1.5 * atr_val
kc_squeeze = (bb_upper < kc_upper) and (bb_lower > kc_lower)

// --- 4. RSI ---
rsi_val = ta.rsi(close_price, rsi_len)

// --- 5. MACD ---
[macd_line, macd_sig_line, macd_hist] = ta.macd(close_price, macd_fast, macd_slow, macd_sig)

// --- 6. EMAs & Trend ---
ema_fast = ta.ema(close_price, ema_fast_len)
ema_mid = ta.ema(close_price, ema_mid_len)
ema_slow = ta.ema(close_price, ema_slow_len)
above_ema_fast = close_price > ema_fast
above_ema_mid = close_price > ema_mid
above_ema_slow = close_price > ema_slow
ema_aligned = (ema_fast > ema_mid) and (ema_mid > ema_slow)

// --- 7. Volume Analysis ---
vol_ma20 = ta.sma(vol, 20)
vol_ratio = vol / vol_ma20
vol_ma5 = ta.sma(vol, 5)
vol_trend = vol_ma5 / vol_ma20
vol_dryup = vol_ratio < 0.7

// --- 8. Range & Contraction ---
pivot_high = ta.highest(high_price, 20)
pivot_low = ta.lowest(low_price, 20)
range_pos = (close_price - pivot_low) / (pivot_high - pivot_low + 1e-10)

recent_range = ta.highest(high_price, 10) - ta.lowest(low_price, 10)
hist_range = ta.highest(high_price, 30) - ta.lowest(low_price, 30)
contraction_ratio = recent_range / (hist_range + 1e-10)

// --- 9. Returns & Momentum ---
ret_5d = (close_price - close_price[5]) / close_price[5] * 100
ret_20d = (close_price - close_price[20]) / close_price[20] * 100
momentum = ret_5d - ret_20d

// =============================================================================
// COMPONENT SCORES (0-100 scale)
// =============================================================================

// 1. Volume/Flow Score (35%)
vol_raw = vol_ratio * 50
vol_score = close_price > close_price[1] ? math.min(vol_raw, 100) : math.max(100 - vol_raw, 0)
vol_score := math.max(0, math.min(100, vol_score))

// 2. Volatility Contraction Score (30%)
squeeze_raw = bb_squeeze ? 80 : 40
squeeze_raw := kc_squeeze ? squeeze_raw + 10 : squeeze_raw
squeeze_raw := vol_dryup ? squeeze_raw + 10 : squeeze_raw
squeeze_score = math.max(0, math.min(100, squeeze_raw))

// 3. Momentum Score (15%)
macd_norm = (macd_hist / close_price * 1000 + 50)
macd_norm := math.max(0, math.min(100, macd_norm))
momentum_score = rsi_val * 0.6 + macd_norm * 0.4

// 4. Trend Score (15%)
trend_score = (above_ema_fast ? 25 : 0) + (above_ema_mid ? 25 : 0) + 
              (above_ema_slow ? 25 : 0) + (ema_aligned ? 25 : 0)

// 5. Mean Reversion Score (5%)
mean_rev_score = 100 - bb_pct * 100
mean_rev_score := math.max(0, math.min(100, mean_rev_score))

// =============================================================================
// COMPOSITE SCORE
// =============================================================================
composite = vol_score * weight_vol + 
            squeeze_score * weight_vcp + 
            momentum_score * weight_mom + 
            trend_score * weight_trd + 
            mean_rev_score * weight_mr

// Smooth the composite for cleaner signals
composite_smooth = ta.ema(composite, 3)

// =============================================================================
// SIGNAL GENERATION
// =============================================================================

// Main signals with hysteresis
bull_signal = composite_smooth > bull_thresh
bear_signal = composite_smooth < bear_thresh

// --- EARLY ENTRY: VCP Breakout Setup ---
early_entry = bb_squeeze and vol_dryup and (momentum > 0) and above_ema_fast and (contraction_ratio < 0.5)

// --- EARLY EXIT: Overbought Exhaustion ---
early_exit = (rsi_val > rsi_overbought) and (vol_ratio < 0.8) and (macd_hist < macd_hist[1]) and (bb_pct > 0.9)

// =============================================================================
// STOP LOSS & TAKE PROFIT LEVELS
// =============================================================================
long_stop = close_price - atr_val * atr_mult_stop
long_tp = close_price + atr_val * atr_mult_tp
short_stop = close_price + atr_val * atr_mult_stop
short_tp = close_price - atr_val * atr_mult_tp

// =============================================================================
// VISUALIZATION
// =============================================================================

// Main Composite Plot
plot(composite_smooth, title="Composite Score", color=color.new(color.blue, 0), linewidth=2)
plot(composite, title="Composite Raw", color=color.new(color.gray, 70), linewidth=1)

// Threshold lines
hline(bull_thresh, "Bullish Threshold", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(50, "Neutral", color=color.new(color.gray, 50), linestyle=hline.style_dotted)
hline(bear_thresh, "Bearish Threshold", color=color.new(color.red, 50), linestyle=hline.style_dashed)

// Background coloring
bg_color = bull_signal ? color.new(color.green, 92) : 
           bear_signal ? color.new(color.red, 92) : 
           color.new(color.gray, 95)
bgcolor(show_bg ? bg_color : na, title="Signal Background")

// Early Entry markers (green triangles below)
plotshape(early_entry and show_early, title="Early Entry", style=shape.triangleup, 
     location=location.bottom, color=color.new(color.lime, 0), size=size.small, 
     text="ENTRY", textcolor=color.new(color.white, 0), textsize=size.tiny)

// Early Exit markers (red triangles above)
plotshape(early_exit and show_early, title="Early Exit", style=shape.triangledown, 
     location=location.top, color=color.new(color.red, 0), size=size.small, 
     text="EXIT", textcolor=color.new(color.white, 0), textsize=size.tiny)

// Bull/Bear signal markers
plotshape(bull_signal and not bull_signal[1], title="Bull Signal", style=shape.circle, 
     location=location.bottom, color=color.new(color.green, 0), size=size.normal)
plotshape(bear_signal and not bear_signal[1], title="Bear Signal", style=shape.circle, 
     location=location.top, color=color.new(color.red, 0), size=size.normal)

// Component score plots (optional)
plot(show_scores ? vol_score : na, title="Vol Score", color=color.new(color.purple, 70), linewidth=1)
plot(show_scores ? squeeze_score : na, title="Squeeze Score", color=color.new(color.orange, 70), linewidth=1)
plot(show_scores ? momentum_score : na, title="Momentum Score", color=color.new(color.yellow, 70), linewidth=1)
plot(show_scores ? trend_score : na, title="Trend Score", color=color.new(color.teal, 70), linewidth=1)
plot(show_scores ? mean_rev_score : na, title="MeanRev Score", color=color.new(color.gray, 70), linewidth=1)

// =============================================================================
// TABLE: COMPONENT BREAKDOWN
// =============================================================================
if barstate.islast
    tbl = table.new(position.top_right, 2, 7, bgcolor=color.new(color.black, 20), 
                   border_width=1, border_color=color.new(color.gray, 50))
    table.cell(tbl, 0, 0, "COMPONENT", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 0, "SCORE", text_color=color.white, text_size=size.small)
    
    table.cell(tbl, 0, 1, "Vol/Flow (" + str.tostring(weight_vol*100, "#.") + "%)", 
              text_color=color.purple, text_size=size.tiny)
    table.cell(tbl, 1, 1, str.tostring(vol_score, "#."), text_color=color.purple, text_size=size.tiny)
    
    table.cell(tbl, 0, 2, "VCP (" + str.tostring(weight_vcp*100, "#.") + "%)", 
              text_color=color.orange, text_size=size.tiny)
    table.cell(tbl, 1, 2, str.tostring(squeeze_score, "#."), text_color=color.orange, text_size=size.tiny)
    
    table.cell(tbl, 0, 3, "Momentum (" + str.tostring(weight_mom*100, "#.") + "%)", 
              text_color=color.yellow, text_size=size.tiny)
    table.cell(tbl, 1, 3, str.tostring(momentum_score, "#."), text_color=color.yellow, text_size=size.tiny)
    
    table.cell(tbl, 0, 4, "Trend (" + str.tostring(weight_trd*100, "#.") + "%)", 
              text_color=color.teal, text_size=size.tiny)
    table.cell(tbl, 1, 4, str.tostring(trend_score, "#."), text_color=color.teal, text_size=size.tiny)
    
    table.cell(tbl, 0, 5, "MeanRev (" + str.tostring(weight_mr*100, "#.") + "%)", 
              text_color=color.gray, text_size=size.tiny)
    table.cell(tbl, 1, 5, str.tostring(mean_rev_score, "#."), text_color=color.gray, text_size=size.tiny)
    
    comp_color = composite_smooth > bull_thresh ? color.green : 
                 composite_smooth < bear_thresh ? color.red : color.white
    table.cell(tbl, 0, 6, "COMPOSITE", text_color=comp_color, text_size=size.small)
    table.cell(tbl, 1, 6, str.tostring(composite_smooth, "#.#"), text_color=comp_color, text_size=size.small)

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(early_entry, title="Early Entry Signal", 
     message="OFC v6: Early Entry detected on {{ticker}} - VCP forming, potential breakout imminent")
alertcondition(early_exit, title="Early Exit Signal", 
     message="OFC v6: Early Exit detected on {{ticker}} - Overbought exhaustion, correction likely")
alertcondition(bull_signal and not bull_signal[1], title="Bullish Composite", 
     message="OFC v6: Bullish composite signal on {{ticker}} - Score: {{plot_0}}")
alertcondition(bear_signal and not bear_signal[1], title="Bearish Composite", 
     message="OFC v6: Bearish composite signal on {{ticker}} - Score: {{plot_0}}")

// =============================================================================
// INFORMATION PANEL
// =============================================================================
plotchar(atr_pct, title="ATR%", char="", display=display.pane)
plotchar(bb_width, title="BB Width%", char="", display=display.pane)
plotchar(vol_ratio, title="Vol Ratio", display=display.pane)
plotchar(rsi_val, title="RSI", display=display.pane)
