//@version=6
indicator("ETF Master Dashboard v6.0", shorttitle="ETF Dash v6", overlay=false, 
     max_lines_count=500, max_labels_count=500, max_bars_back=500)

// =============================================================================
// ETF MASTER DASHBOARD v6.0
// =============================================================================
// Monitors 17 thematic ETFs with Options Flow Composite scoring:
// SOXX, IWM, SPY, QQQ, AIPO, XBI, ARKF, ARKQ, ICLN, SMH, DRAM, UTES, URA, BOTZ, TCAI, AIVC, WGMI
//
// Features:
// - Real-time composite score for each ETF
// - Early entry/exit detection
// - Sector rotation heatmap
// - Bullish/Bearish/Neutral classification
// =============================================================================

group_calc = "Composite Calculation"
group_display = "Display Options"
group_alerts = "Alert Settings"

w_vol = input.float(0.35, "Volume Weight", minval=0, maxval=1, step=0.05, group=group_calc)
w_vcp = input.float(0.30, "Vol Contraction Weight", minval=0, maxval=1, step=0.05, group=group_calc)
w_mom = input.float(0.15, "Momentum Weight", minval=0, maxval=1, step=0.05, group=group_calc)
w_trd = input.float(0.15, "Trend Weight", minval=0, maxval=1, step=0.05, group=group_calc)
w_mr  = input.float(0.05, "Mean Reversion Weight", minval=0, maxval=1, step=0.05, group=group_calc)

bull_thr = input.int(65, "Bullish Threshold", minval=50, maxval=100, group=group_calc)
bear_thr = input.int(35, "Bearish Threshold", minval=0, maxval=50, group=group_calc)

show_table = input.bool(true, "Show ETF Table", group=group_display)
show_heatmap = input.bool(true, "Show Sector Heatmap", group=group_display)
show_signals = input.bool(true, "Show Signal Markers", group=group_display)

alert_bull = input.bool(true, "Alert on Bullish Signal", group=group_alerts)
alert_bear = input.bool(true, "Alert on Bearish Signal", group=group_alerts)
alert_early = input.bool(true, "Alert on Early Entry", group=group_alerts)

// ETF Definitions
var etf_names = array.from(
     "SOXX", "IWM", "SPY", "QQQ", "AIPO",
     "XBI", "ARKF", "ARKQ", "ICLN", "SMH",
     "DRAM", "UTES", "URA", "BOTZ", "TCAI",
     "AIVC", "WGMI"
     )

var etf_sectors = array.from(
     "Semiconductors", "Small Cap", "Broad Market", "Tech Mega", "AI Power",
     "Biotech", "Fintech", "Autonomous", "Clean Energy", "Semiconductors",
     "Memory Chips", "Utilities", "Uranium", "Robotics/AI", "AI Infra",
     "AI Value", "BTC Mining"
     )

var etf_colors = array.from(
     color.orange, color.blue, color.gray, color.purple, color.red,
     color.green, color.teal, color.navy, color.lime, color.orange,
     color.fuchsia, color.yellow, color.maroon, color.olive, color.aqua,
     color.purple, color.orange
     )

// Composite Calculation Function
calc_composite(ticker) =>
    c = request.security(ticker, timeframe.period, close, gaps=barmerge.gaps_off)
    h = request.security(ticker, timeframe.period, high, gaps=barmerge.gaps_off)
    l = request.security(ticker, timeframe.period, low, gaps=barmerge.gaps_off)
    v = request.security(ticker, timeframe.period, volume, gaps=barmerge.gaps_off)
    
    valid = not na(c) and not na(v) and c > 0
    
    tr = math.max(h - l, math.max(math.abs(h - c[1]), math.abs(l - c[1])))
    atr14 = ta.sma(tr, 14)
    
    bb_mid = ta.sma(c, 20)
    bb_std = ta.stdev(c, 20)
    bb_up = bb_mid + 2 * bb_std
    bb_lo = bb_mid - 2 * bb_std
    bb_w = (bb_up - bb_lo) / bb_mid * 100
    bb_wm = ta.sma(bb_w, 20)
    bb_pct = (c - bb_lo) / (bb_up - bb_lo + 1e-10)
    bb_sq = bb_w < bb_wm * 0.85
    
    rsi14 = ta.rsi(c, 14)
    [macd_l, macd_s, macd_h] = ta.macd(c, 12, 26, 9)
    
    ema20 = ta.ema(c, 20)
    ema50 = ta.ema(c, 50)
    abv20 = c > ema20
    abv50 = c > ema50
    aln = ema20 > ema50
    
    vma20 = ta.sma(v, 20)
    vr = v / vma20
    vd = vr < 0.7
    
    r5 = (c - c[5]) / c[5] * 100
    mom = ta.ema(c, 12) - ta.ema(c, 26)
    
    vs = c > c[1] ? math.min(vr * 50, 100) : math.max(100 - vr * 50, 0)
    ss = bb_sq ? (vd ? 100 : 80) : (vd ? 60 : 40)
    mn = macd_h / c * 1000 + 50
    ms = rsi14 * 0.6 + math.max(0, math.min(100, mn)) * 0.4
    ts = (abv20 ? 33 : 0) + (abv50 ? 33 : 0) + (aln ? 34 : 0)
    mr = 100 - bb_pct * 100
    
    comp = vs * w_vol + ss * w_vcp + ms * w_mom + ts * w_trd + math.max(0, math.min(100, mr)) * w_mr
    comp_s = ta.ema(comp, 3)
    
    bull = comp_s > bull_thr
    bear = comp_s < bear_thr
    ee = bb_sq and vd and mom > 0 and abv20
    ex = rsi14 > 75 and vr < 0.8 and macd_h < macd_h[1] and bb_pct > 0.9
    
    [valid, comp_s, bull, bear, ee, ex, r5]

// Calculate for all 17 ETFs
[soxx_v, soxx_c, soxx_b, soxx_br, soxx_ee, soxx_ex, soxx_r5] = calc_composite("NASDAQ:SOXX")
[iwm_v, iwm_c, iwm_b, iwm_br, iwm_ee, iwm_ex, iwm_r5] = calc_composite("AMEX:IWM")
[spy_v, spy_c, spy_b, spy_br, spy_ee, spy_ex, spy_r5] = calc_composite("AMEX:SPY")
[qqq_v, qqq_c, qqq_b, qqq_br, qqq_ee, qqq_ex, qqq_r5] = calc_composite("NASDAQ:QQQ")
[aipo_v, aipo_c, aipo_b, aipo_br, aipo_ee, aipo_ex, aipo_r5] = calc_composite("AMEX:AIPO")
[xbi_v, xbi_c, xbi_b, xbi_br, xbi_ee, xbi_ex, xbi_r5] = calc_composite("AMEX:XBI")
[arkf_v, arkf_c, arkf_b, arkf_br, arkf_ee, arkf_ex, arkf_r5] = calc_composite("AMEX:ARKF")
[arkq_v, arkq_c, arkq_b, arkq_br, arkq_ee, arkq_ex, arkq_r5] = calc_composite("AMEX:ARKQ")
[icln_v, icln_c, icln_b, icln_br, icln_ee, icln_ex, icln_r5] = calc_composite("NASDAQ:ICLN")
[smh_v, smh_c, smh_b, smh_br, smh_ee, smh_ex, smh_r5] = calc_composite("NASDAQ:SMH")
[dram_v, dram_c, dram_b, dram_br, dram_ee, dram_ex, dram_r5] = calc_composite("NASDAQ:DRAM")
[utes_v, utes_c, utes_b, utes_br, utes_ee, utes_ex, utes_r5] = calc_composite("AMEX:UTES")
[ura_v, ura_c, ura_b, ura_br, ura_ee, ura_ex, ura_r5] = calc_composite("AMEX:URA")
[botz_v, botz_c, botz_b, botz_br, botz_ee, botz_ex, botz_r5] = calc_composite("NASDAQ:BOTZ")
[tcai_v, tcai_c, tcai_b, tcai_br, tcai_ee, tcai_ex, tcai_r5] = calc_composite("NYSE:TCAI")
[aivc_v, aivc_c, aivc_b, aivc_br, aivc_ee, aivc_ex, aivc_r5] = calc_composite("AMEX:AIVC")
[wgmi_v, wgmi_c, wgmi_b, wgmi_br, wgmi_ee, wgmi_ex, wgmi_r5] = calc_composite("NASDAQ:WGMI")

// Arrays for display
var arr_valid = array.new_bool(17)
var arr_comp  = array.new_float(17)
var arr_bull  = array.new_bool(17)
var arr_bear  = array.new_bool(17)
var arr_ee    = array.new_bool(17)
var arr_ex    = array.new_bool(17)
var arr_r5    = array.new_float(17)

if barstate.islast
    array.set(arr_valid, 0, soxx_v)  ; array.set(arr_comp, 0, soxx_c)  ; array.set(arr_bull, 0, soxx_b)  ; array.set(arr_bear, 0, soxx_br)  ; array.set(arr_ee, 0, soxx_ee)  ; array.set(arr_r5, 0, soxx_r5)
    array.set(arr_valid, 1, iwm_v)   ; array.set(arr_comp, 1, iwm_c)   ; array.set(arr_bull, 1, iwm_b)   ; array.set(arr_bear, 1, iwm_br)   ; array.set(arr_ee, 1, iwm_ee)   ; array.set(arr_r5, 1, iwm_r5)
    array.set(arr_valid, 2, spy_v)   ; array.set(arr_comp, 2, spy_c)   ; array.set(arr_bull, 2, spy_b)   ; array.set(arr_bear, 2, spy_br)   ; array.set(arr_ee, 2, spy_ee)   ; array.set(arr_r5, 2, spy_r5)
    array.set(arr_valid, 3, qqq_v)   ; array.set(arr_comp, 3, qqq_c)   ; array.set(arr_bull, 3, qqq_b)   ; array.set(arr_bear, 3, qqq_br)   ; array.set(arr_ee, 3, qqq_ee)   ; array.set(arr_r5, 3, qqq_r5)
    array.set(arr_valid, 4, aipo_v)  ; array.set(arr_comp, 4, aipo_c)  ; array.set(arr_bull, 4, aipo_b)  ; array.set(arr_bear, 4, aipo_br)  ; array.set(arr_ee, 4, aipo_ee)  ; array.set(arr_r5, 4, aipo_r5)
    array.set(arr_valid, 5, xbi_v)   ; array.set(arr_comp, 5, xbi_c)   ; array.set(arr_bull, 5, xbi_b)   ; array.set(arr_bear, 5, xbi_br)   ; array.set(arr_ee, 5, xbi_ee)   ; array.set(arr_r5, 5, xbi_r5)
    array.set(arr_valid, 6, arkf_v)  ; array.set(arr_comp, 6, arkf_c)  ; array.set(arr_bull, 6, arkf_b)  ; array.set(arr_bear, 6, arkf_br)  ; array.set(arr_ee, 6, arkf_ee)  ; array.set(arr_r5, 6, arkf_r5)
    array.set(arr_valid, 7, arkq_v)  ; array.set(arr_comp, 7, arkq_c)  ; array.set(arr_bull, 7, arkq_b)  ; array.set(arr_bear, 7, arkq_br)  ; array.set(arr_ee, 7, arkq_ee)  ; array.set(arr_r5, 7, arkq_r5)
    array.set(arr_valid, 8, icln_v)  ; array.set(arr_comp, 8, icln_c)  ; array.set(arr_bull, 8, icln_b)  ; array.set(arr_bear, 8, icln_br)  ; array.set(arr_ee, 8, icln_ee)  ; array.set(arr_r5, 8, icln_r5)
    array.set(arr_valid, 9, smh_v)   ; array.set(arr_comp, 9, smh_c)   ; array.set(arr_bull, 9, smh_b)   ; array.set(arr_bear, 9, smh_br)   ; array.set(arr_ee, 9, smh_ee)   ; array.set(arr_r5, 9, smh_r5)
    array.set(arr_valid, 10, dram_v) ; array.set(arr_comp, 10, dram_c) ; array.set(arr_bull, 10, dram_b) ; array.set(arr_bear, 10, dram_br) ; array.set(arr_ee, 10, dram_ee) ; array.set(arr_r5, 10, dram_r5)
    array.set(arr_valid, 11, utes_v) ; array.set(arr_comp, 11, utes_c) ; array.set(arr_bull, 11, utes_b) ; array.set(arr_bear, 11, utes_br) ; array.set(arr_ee, 11, utes_ee) ; array.set(arr_r5, 11, utes_r5)
    array.set(arr_valid, 12, ura_v)  ; array.set(arr_comp, 12, ura_c)  ; array.set(arr_bull, 12, ura_b)  ; array.set(arr_bear, 12, ura_br)  ; array.set(arr_ee, 12, ura_ee)  ; array.set(arr_r5, 12, ura_r5)
    array.set(arr_valid, 13, botz_v) ; array.set(arr_comp, 13, botz_c) ; array.set(arr_bull, 13, botz_b) ; array.set(arr_bear, 13, botz_br) ; array.set(arr_ee, 13, botz_ee) ; array.set(arr_r5, 13, botz_r5)
    array.set(arr_valid, 14, tcai_v) ; array.set(arr_comp, 14, tcai_c) ; array.set(arr_bull, 14, tcai_b) ; array.set(arr_bear, 14, tcai_br) ; array.set(arr_ee, 14, tcai_ee) ; array.set(arr_r5, 14, tcai_r5)
    array.set(arr_valid, 15, aivc_v) ; array.set(arr_comp, 15, aivc_c) ; array.set(arr_bull, 15, aivc_b) ; array.set(arr_bear, 15, aivc_br) ; array.set(arr_ee, 15, aivc_ee) ; array.set(arr_r5, 15, aivc_r5)
    array.set(arr_valid, 16, wgmi_v) ; array.set(arr_comp, 16, wgmi_c) ; array.set(arr_bull, 16, wgmi_b) ; array.set(arr_bear, 16, wgmi_br) ; array.set(arr_ee, 16, wgmi_ee) ; array.set(arr_r5, 16, wgmi_r5)

// Main ETF Table
if show_table and barstate.islast
    var tbl = table.new(position.top_right, 7, 18, 
         bgcolor=color.new(color.black, 10), 
         border_width=1, 
         border_color=color.new(color.gray, 50))
    
    table.cell(tbl, 0, 0, "ETF", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 1, 0, "SECTOR", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 2, 0, "SCORE", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 3, 0, "5D%", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 4, 0, "SIGNAL", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 5, 0, "EARLY", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(tbl, 6, 0, "STATUS", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    
    for i = 0 to 16
        valid = array.get(arr_valid, i)
        name = array.get(etf_names, i)
        sector = array.get(etf_sectors, i)
        comp = array.get(arr_comp, i)
        bull = array.get(arr_bull, i)
        bear = array.get(arr_bear, i)
        ee = array.get(arr_ee, i)
        r5 = array.get(arr_r5, i)
        row = i + 1
        
        if valid
            sig_color = bull ? color.new(color.green, 70) : bear ? color.new(color.red, 70) : color.new(color.gray, 80)
            comp_color = bull ? color.green : bear ? color.red : color.gray
            early_txt = ee ? "ENTRY" : ""
            early_color = ee ? color.new(color.lime, 30) : color.new(color.gray, 80)
            status_txt = bull ? "BULLISH" : bear ? "BEARISH" : "NEUTRAL"
            status_color = bull ? color.new(color.green, 50) : bear ? color.new(color.red, 50) : color.new(color.gray, 70)
            
            table.cell(tbl, 0, row, name, text_color=array.get(etf_colors, i), text_size=size.tiny, bgcolor=sig_color)
            table.cell(tbl, 1, row, sector, text_color=color.white, text_size=size.tiny, bgcolor=sig_color)
            table.cell(tbl, 2, row, str.tostring(comp, "#.#"), text_color=comp_color, text_size=size.tiny, bgcolor=sig_color)
            table.cell(tbl, 3, row, str.tostring(r5, "+#.#;-#.#;0.0") + "%", text_color=r5 > 0 ? color.green : r5 < 0 ? color.red : color.gray, text_size=size.tiny, bgcolor=sig_color)
            table.cell(tbl, 4, row, bull ? "BUY" : bear ? "SELL" : "HOLD", text_color=comp_color, text_size=size.tiny, bgcolor=sig_color)
            table.cell(tbl, 5, row, early_txt, text_color=color.black, text_size=size.tiny, bgcolor=early_color)
            table.cell(tbl, 6, row, status_txt, text_color=comp_color, text_size=size.tiny, bgcolor=status_color)
        else
            for col = 0 to 6
                table.cell(tbl, col, row, "--", text_color=color.gray, text_size=size.tiny)

// Sector Heatmap
if show_heatmap and barstate.islast
    var heat_tbl = table.new(position.bottom_left, 6, 4, 
         bgcolor=color.new(color.black, 20), 
         border_width=1, 
         border_color=color.new(color.gray, 50))
    
    table.cell(heat_tbl, 0, 0, "SECTOR ROTATION MAP", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 30), colspan=6)
    
    semi_avg = (soxx_c + smh_c + dram_c) / 3
    semi_color = semi_avg > 60 ? color.new(color.green, 30) : semi_avg < 40 ? color.new(color.red, 30) : color.new(color.gray, 50)
    table.cell(heat_tbl, 0, 1, "SEMIS", text_color=color.white, text_size=size.tiny, bgcolor=semi_color)
    table.cell(heat_tbl, 1, 1, str.tostring(semi_avg, "#.#"), text_color=semi_avg > 60 ? color.green : semi_avg < 40 ? color.red : color.gray, text_size=size.tiny, bgcolor=semi_color)
    
    ai_avg = (botz_c + tcai_c + aivc_c) / 3
    ai_color = ai_avg > 60 ? color.new(color.green, 30) : ai_avg < 40 ? color.new(color.red, 30) : color.new(color.gray, 50)
    table.cell(heat_tbl, 2, 1, "AI/TECH", text_color=color.white, text_size=size.tiny, bgcolor=ai_color)
    table.cell(heat_tbl, 3, 1, str.tostring(ai_avg, "#.#"), text_color=ai_avg > 60 ? color.green : ai_avg < 40 ? color.red : color.gray, text_size=size.tiny, bgcolor=ai_color)
    
    power_avg = (aipo_c + utes_c) / 2
    power_color = power_avg > 60 ? color.new(color.green, 30) : power_avg < 40 ? color.new(color.red, 30) : color.new(color.gray, 50)
    table.cell(heat_tbl, 4, 1, "POWER", text_color=color.white, text_size=size.tiny, bgcolor=power_color)
    table.cell(heat_tbl, 5, 1, str.tostring(power_avg, "#.#"), text_color=power_avg > 60 ? color.green : power_avg < 40 ? color.red : color.gray, text_size=size.tiny, bgcolor=power_color)
    
    spec_avg = (xbi_c + arkf_c + arkq_c + icln_c + ura_c + wgmi_c) / 6
    spec_color = spec_avg > 60 ? color.new(color.green, 30) : spec_avg < 40 ? color.new(color.red, 30) : color.new(color.gray, 50)
    table.cell(heat_tbl, 0, 2, "SPECULATIVE", text_color=color.white, text_size=size.tiny, bgcolor=spec_color)
    table.cell(heat_tbl, 1, 2, str.tostring(spec_avg, "#.#"), text_color=spec_avg > 60 ? color.green : spec_avg < 40 ? color.red : color.gray, text_size=size.tiny, bgcolor=spec_color)
    
    broad_avg = (spy_c + qqq_c + iwm_c) / 3
    broad_color = broad_avg > 60 ? color.new(color.green, 30) : broad_avg < 40 ? color.new(color.red, 30) : color.new(color.gray, 50)
    table.cell(heat_tbl, 2, 2, "BROAD", text_color=color.white, text_size=size.tiny, bgcolor=broad_color)
    table.cell(heat_tbl, 3, 2, str.tostring(broad_avg, "#.#"), text_color=broad_avg > 60 ? color.green : broad_avg < 40 ? color.red : color.gray, text_size=size.tiny, bgcolor=broad_color)
    
    all_avg = (soxx_c + iwm_c + spy_c + qqq_c + aipo_c + xbi_c + arkf_c + arkq_c + icln_c + smh_c + dram_c + utes_c + ura_c + botz_c + tcai_c + aivc_c + wgmi_c) / 17
    regime_color = all_avg > 60 ? color.new(color.green, 30) : all_avg < 40 ? color.new(color.red, 30) : color.new(color.yellow, 30)
    table.cell(heat_tbl, 4, 2, "REGIME", text_color=color.white, text_size=size.tiny, bgcolor=regime_color)
    regime_txt = all_avg > 60 ? "RISK-ON" : all_avg < 40 ? "RISK-OFF" : "NEUTRAL"
    table.cell(heat_tbl, 5, 2, regime_txt, text_color=all_avg > 60 ? color.green : all_avg < 40 ? color.red : color.yellow, text_size=size.tiny, bgcolor=regime_color)
    
    bull_count = int(soxx_b) + int(iwm_b) + int(spy_b) + int(qqq_b) + int(aipo_b) + int(xbi_b) + int(arkf_b) + int(arkq_b) + int(icln_b) + int(smh_b) + int(dram_b) + int(utes_b) + int(ura_b) + int(botz_b) + int(tcai_b) + int(aivc_b) + int(wgmi_b)
    ee_count = int(soxx_ee) + int(iwm_ee) + int(spy_ee) + int(qqq_ee) + int(aipo_ee) + int(xbi_ee) + int(arkf_ee) + int(arkq_ee) + int(icln_ee) + int(smh_ee) + int(dram_ee) + int(utes_ee) + int(ura_ee) + int(botz_ee) + int(tcai_ee) + int(aivc_ee) + int(wgmi_ee)
    
    table.cell(heat_tbl, 0, 3, "BULLISH: " + str.tostring(bull_count) + "/17", text_color=color.green, text_size=size.tiny, bgcolor=color.new(color.black, 10))
    table.cell(heat_tbl, 2, 3, "EARLY: " + str.tostring(ee_count), text_color=color.lime, text_size=size.tiny, bgcolor=color.new(color.black, 10))
    table.cell(heat_tbl, 4, 3, "AVG: " + str.tostring(all_avg, "#.#"), text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.black, 10), colspan=2)

// Alerts
any_ee = soxx_ee or iwm_ee or spy_ee or qqq_ee or aipo_ee or xbi_ee or arkf_ee or arkq_ee or icln_ee or smh_ee or dram_ee or utes_ee or ura_ee or botz_ee or tcai_ee or aivc_ee or wgmi_ee
alertcondition(any_ee, title="Dashboard: Early Entry Detected", 
     message="ETF Dashboard: Early entry signal detected across monitored ETFs")

// Summary Plot
avg_comp = (soxx_c + smh_c + dram_c + qqq_c + spy_c + iwm_c + botz_c + tcai_c + aivc_c + aipo_c + utes_c + xbi_c + arkf_c + arkq_c + icln_c + ura_c + wgmi_c) / 17
plot(avg_comp, title="Avg Composite", color=color.new(color.blue, 30), linewidth=2)

hline(bull_thr, "Bullish Line", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(50, "Neutral Line", color=color.new(color.gray, 50), linestyle=hline.style_dotted)
hline(bear_thr, "Bearish Line", color=color.new(color.red, 50), linestyle=hline.style_dashed)
