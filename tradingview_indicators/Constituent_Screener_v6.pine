//@version=6
indicator("Multi-ETF Constituent Screener v6.0", shorttitle="ETF Screener v6", overlay=false,
     max_lines_count=500, max_labels_count=500, max_bars_back=500)

// =============================================================================
// MULTI-ETF CONSTITUENT SCREENER v6.0
// =============================================================================
// Tracks the top 40 individual stocks with highest ETF overlap conviction
// from 17 thematic ETFs (SOXX, IWM, SPY, QQQ, AIPO, XBI, ARKF, ARKQ, ICLN,
// SMH, DRAM, UTES, URA, BOTZ, TCAI, AIVC, WGMI)
//
// Features:
// - Options Flow Composite score per stock
// - Early entry/exit signals
// - ETF overlap count (conviction ranking)
// - 5-day performance tracking
// - Sortable by composite, trend, momentum, or volume
// =============================================================================

group_calc = "Composite Weights"
group_disp = "Display"
group_filt = "Filters"

w_vol = input.float(0.35, "Volume", minval=0, maxval=1, step=0.05, group=group_calc)
w_vcp = input.float(0.30, "Vol Contraction", minval=0, maxval=1, step=0.05, group=group_calc)
w_mom = input.float(0.15, "Momentum", minval=0, maxval=1, step=0.05, group=group_calc)
w_trd = input.float(0.15, "Trend", minval=0, maxval=1, step=0.05, group=group_calc)
w_mr  = input.float(0.05, "Mean Reversion", minval=0, maxval=1, step=0.05, group=group_calc)

bull_thr = input.int(65, "Bullish Threshold", minval=50, maxval=100, group=group_calc)
bear_thr = input.int(35, "Bearish Threshold", minval=0, maxval=50, group=group_calc)

sort_opt = input.string("Composite", "Sort By", options=["Composite", "Conviction", "Momentum", "5D Return"], group=group_disp)
min_conf = input.int(2, "Min ETF Conviction", minval=1, maxval=8, group=group_filt)
show_early_only = input.bool(false, "Show Early Entries Only", group=group_filt)

var scr_tickers = array.from(
    "NASDAQ:NVDA", "NASDAQ:AMD", "NASDAQ:MU", "NASDAQ:AVGO",
    "NASDAQ:AMAT", "NASDAQ:TER", "AMEX:SOXX",
    "NASDAQ:KLAC", "NASDAQ:MRVL", "NYSE:TSM", "NASDAQ:LRCX",
    "NASDAQ:TXN", "NASDAQ:ADI", "NASDAQ:MPWR", "NASDAQ:QCOM",
    "NASDAQ:ASML", "NASDAQ:TSLA", "NASDAQ:INTC", "NASDAQ:NXPI",
    "NASDAQ:MCHP", "NASDAQ:GOOGL", "NASDAQ:CEG", "NASDAQ:BE",
    "NASDAQ:AAPL", "NASDAQ:MSFT", "NASDAQ:AMZN",
    "NASDAQ:ON", "NASDAQ:ENTG", "NASDAQ:CDNS", "NASDAQ:SNPS",
    "NASDAQ:ENTG", "AMEX:HUT", "AMEX:RIOT", "NYSE:VST",
    "AMEX:TLN", "NYSE:NRG", "NASDAQ:OKLO", "NASDAQ:PLUG",
    "NASDAQ:FSLR", "NASDAQ:ENPH", "NASDAQ:COIN", "NASDAQ:ISRG",
    "NASDAQ:WDC", "NASDAQ:STX", "NASDAQ:SNDK", "NASDAQ:WULF",
    "NASDAQ:CIFR", "NASDAQ:CORZ", "NASDAQ:META", "NASDAQ:SOFI",
    "AMEX:ARKK", "NYSE:DELL", "NASDAQ:CRDO", "NASDAQ:ALAB"
)

var scr_names = array.from(
    "NVDA", "AMD", "MU", "AVGO",
    "AMAT", "TER", "SOXX",
    "KLAC", "MRVL", "TSM", "LRCX", "TXN", "ADI", "MPWR", "QCOM", "ASML", "TSLA", "INTC", "NXPI",
    "MCHP", "GOOGL", "CEG", "BE", "AAPL", "MSFT", "AMZN",
    "ON", "ENTG", "CDNS", "SNPS", "ENTG", "HUT", "RIOT", "VST",
    "TLN", "NRG", "OKLO", "PLUG", "FSLR", "ENPH", "COIN", "ISRG",
    "WDC", "STX", "SNDK", "WULF", "CIFR", "CORZ", "META", "SOFI",
    "ARKK", "DELL", "CRDO", "ALAB"
)

var scr_conf = array.from(
    8, 6, 6, 6,
    5, 5, 5,
    4, 4, 4, 4, 4, 4, 4, 4, 4, 4, 4, 4,
    3, 3, 3, 3, 3, 3, 3,
    2, 2, 2, 2, 2, 2, 2, 2,
    2, 2, 2, 2, 2, 2, 2, 2,
    2, 2, 2, 2, 2, 2, 2, 2,
    2, 2, 2, 2
)

var scr_sectors = array.from(
    "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR",
    "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR",
    "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR",
    "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "EV/AUTO",
    "SEMICONDUCTOR", "SEMICONDUCTOR",
    "SEMICONDUCTOR", "TECH", "NUCLEAR/PWR", "CLEAN ENERGY", "TECH", "TECH", "TECH",
    "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR", "SEMICONDUCTOR",
    "BTC MINING", "BTC MINING", "NUCLEAR/PWR",
    "NUCLEAR/PWR", "POWER", "NUCLEAR/PWR", "CLEAN ENERGY", "CLEAN ENERGY", "CLEAN ENERGY",
    "FINTECH/CRYPTO", "ROBOTICS", "STORAGE", "STORAGE", "STORAGE",
    "BTC MINING", "BTC MINING", "BTC MINING", "SOCIAL MEDIA", "FINTECH",
    "INNOVATION", "AI INFRA", "SEMICONDUCTOR", "SEMICONDUCTOR"
)

get_sector_color(sector) =>
    sector == "SEMICONDUCTOR" ? color.orange :
    sector == "TECH" ? color.blue :
    sector == "NUCLEAR/PWR" ? color.yellow :
    sector == "CLEAN ENERGY" ? color.green :
    sector == "EV/AUTO" ? color.red :
    sector == "BTC MINING" ? color.fuchsia :
    sector == "STORAGE" ? color.teal :
    sector == "FINTECH" ? color.navy :
    sector == "ROBOTICS" ? color.purple :
    sector == "SOCIAL MEDIA" ? color.aqua :
    sector == "INNOVATION" ? color.maroon :
    sector == "AI INFRA" ? color.lime :
    color.gray

calc_score(ticker) =>
    c = request.security(ticker, timeframe.period, close, gaps=barmerge.gaps_off)
    h = request.security(ticker, timeframe.period, high, gaps=barmerge.gaps_off)
    l = request.security(ticker, timeframe.period, low, gaps=barmerge.gaps_off)
    v = request.security(ticker, timeframe.period, volume, gaps=barmerge.gaps_off)
    
    valid = not na(c) and not na(v) and c > 0
    
    tr = math.max(h - l, math.max(math.abs(h - c[1]), math.abs(l - c[1])))
    atr14 = ta.sma(tr, 14)
    
    bb_mid = ta.sma(c, 20)
    bb_w = (bb_mid + 2 * ta.stdev(c, 20) - (bb_mid - 2 * ta.stdev(c, 20))) / bb_mid * 100
    bb_wm = ta.sma(bb_w, 20)
    bb_lo = bb_mid - 2 * ta.stdev(c, 20)
    bb_up = bb_mid + 2 * ta.stdev(c, 20)
    bb_pct = (c - bb_lo) / (bb_up - bb_lo + 1e-10)
    bb_sq = bb_w < bb_wm * 0.85
    
    rsi14 = ta.rsi(c, 14)
    [_, _, macd_h] = ta.macd(c, 12, 26, 9)
    
    ema20 = ta.ema(c, 20)
    ema50 = ta.ema(c, 50)
    abv20 = c > ema20
    abv50 = c > ema50
    aln = ema20 > ema50
    
    vma20 = ta.sma(v, 20)
    vr = v / vma20
    vd = vr < 0.7
    
    r5 = (c - c[5]) / c[5] * 100
    mom = ta.ema(c, 12) - ta.ema(c, 26)
    
    vs = c > c[1] ? math.min(vr * 50, 100) : math.max(100 - vr * 50, 0)
    ss = bb_sq ? (vd ? 100 : 80) : (vd ? 60 : 40)
    mn = macd_h / c * 1000 + 50
    ms = rsi14 * 0.6 + math.max(0, math.min(100, mn)) * 0.4
    ts = (abv20 ? 33 : 0) + (abv50 ? 33 : 0) + (aln ? 34 : 0)
    mrs = 100 - bb_pct * 100
    
    comp = vs * w_vol + ss * w_vcp + ms * w_mom + ts * w_trd + math.max(0, math.min(100, mrs)) * w_mr
    comp_s = ta.ema(comp, 3)
    
    bull = comp_s > bull_thr
    bear = comp_s < bear_thr
    ee = bb_sq and vd and mom > 0 and abv20
    ex = rsi14 > 75 and vr < 0.8 and macd_h < macd_h[1] and bb_pct > 0.9
    
    [valid, comp_s, bull, bear, ee, ex, vs, ss, ms, ts, r5, vr, rsi14]

N_STOCKS = 54

var arr_s_valid = array.new_bool(N_STOCKS)
var arr_s_comp  = array.new_float(N_STOCKS)
var arr_s_bull  = array.new_bool(N_STOCKS)
var arr_s_bear  = array.new_bool(N_STOCKS)
var arr_s_ee    = array.new_bool(N_STOCKS)
var arr_s_ex    = array.new_bool(N_STOCKS)
var arr_s_vs    = array.new_float(N_STOCKS)
var arr_s_ss    = array.new_float(N_STOCKS)
var arr_s_ms    = array.new_float(N_STOCKS)
var arr_s_ts    = array.new_float(N_STOCKS)
var arr_s_r5    = array.new_float(N_STOCKS)
var arr_s_vr    = array.new_float(N_STOCKS)
var arr_s_rsi   = array.new_float(N_STOCKS)

if barstate.islast
    for i = 0 to N_STOCKS - 1
        ticker = array.get(scr_tickers, i)
        [vld, cp, bl, br, e_e, e_x, v_s, s_s, m_s, t_s, r_5, v_r, r_s] = calc_score(ticker)
        array.set(arr_s_valid, i, vld)
        array.set(arr_s_comp,  i, cp)
        array.set(arr_s_bull,  i, bl)
        array.set(arr_s_bear,  i, br)
        array.set(arr_s_ee,    i, e_e)
        array.set(arr_s_ex,    i, e_x)
        array.set(arr_s_vs,    i, v_s)
        array.set(arr_s_ss,    i, s_s)
        array.set(arr_s_ms,    i, m_s)
        array.set(arr_s_ts,    i, t_s)
        array.set(arr_s_r5,    i, r_5)
        array.set(arr_s_vr,    i, v_r)
        array.set(arr_s_rsi,   i, r_s)

if barstate.islast
    var indices = array.new_int(N_STOCKS)
    for i = 0 to N_STOCKS - 1
        array.set(indices, i, i)
    
    var filtered = array.new_int(0)
    for i = 0 to N_STOCKS - 1
        if array.get(arr_s_valid, i) and array.get(scr_conf, i) >= min_conf
            if not show_early_only or array.get(arr_s_ee, i)
                array.push(filtered, i)
    
    sort_key = sort_opt == "Composite" ? arr_s_comp :
               sort_opt == "Conviction" ? scr_conf :
               sort_opt == "Momentum" ? arr_s_ms :
               arr_s_r5
    
    fn = array.size(filtered)
    if fn > 1
        for i = 0 to fn - 2
            for j = 0 to fn - 2 - i
                idx1 = array.get(filtered, j)
                idx2 = array.get(filtered, j + 1)
                val1 = array.get(sort_key, idx1)
                val2 = array.get(sort_key, idx2)
                if val1 < val2
                    array.set(filtered, j, idx2)
                    array.set(filtered, j + 1, idx1)
    
    display_count = math.min(fn, 40)
    
    var tbl = table.new(position.top_right, 9, display_count + 1,
        bgcolor=color.new(color.black, 10),
        border_width=1,
        border_color=color.new(color.gray, 50))
    
    hdr_bg = color.new(color.gray, 40)
    table.cell(tbl, 0, 0, "RANK", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 1, 0, "TICKER", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 2, 0, "SECTOR", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 3, 0, "SCORE", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 4, 0, "5D%", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 5, 0, "SIGNAL", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 6, 0, "ENTRY", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 7, 0, "CONF", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    table.cell(tbl, 8, 0, "STATUS", text_color=color.white, text_size=size.tiny, bgcolor=hdr_bg)
    
    for row = 0 to display_count - 1
        idx = array.get(filtered, row)
        name = array.get(scr_names, idx)
        sector = array.get(scr_sectors, idx)
        conf = array.get(scr_conf, idx)
        comp = array.get(arr_s_comp, idx)
        bull = array.get(arr_s_bull, idx)
        bear = array.get(arr_s_bear, idx)
        ee = array.get(arr_s_ee, idx)
        ex = array.get(arr_s_ex, idx)
        r5 = array.get(arr_s_r5, idx)
        
        row_idx = row + 1
        sec_col = get_sector_color(sector)
        
        bg = bull ? color.new(color.green, 75) :
             bear ? color.new(color.red, 75) :
             ee ? color.new(color.lime, 80) :
             color.new(color.gray, 85)
        
        comp_col = bull ? color.green : bear ? color.red : ee ? color.lime : color.gray
        
        table.cell(tbl, 0, row_idx, str.tostring(row + 1), text_color=color.white, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 1, row_idx, name, text_color=sec_col, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 2, row_idx, sector, text_color=color.new(sec_col, 30), text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 3, row_idx, str.tostring(comp, "#.#"), text_color=comp_col, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 4, row_idx, str.tostring(r5, "+#.#;-#.#;0.0"), 
            text_color=r5 > 0 ? color.green : r5 < 0 ? color.red : color.gray, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 5, row_idx, bull ? "BUY" : bear ? "SELL" : "HOLD", 
            text_color=comp_col, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 6, row_idx, ee ? "EARLY" : ex ? "EXIT" : "", 
            text_color=ee ? color.black : ex ? color.red : color.gray, text_size=size.tiny, 
            bgcolor=ee ? color.new(color.lime, 30) : ex ? color.new(color.red, 40) : bg)
        table.cell(tbl, 7, row_idx, str.tostring(conf) + " ETFs", text_color=color.yellow, text_size=size.tiny, bgcolor=bg)
        table.cell(tbl, 8, row_idx, bull ? "BULLISH" : bear ? "BEARISH" : ee ? "WATCH" : "NEUTRAL", 
            text_color=comp_col, text_size=size.tiny, bgcolor=bg)

if barstate.islast
    bull_total = 0
    bear_total = 0
    ee_total = 0
    valid_total = 0
    for i = 0 to N_STOCKS - 1
        if array.get(arr_s_valid, i) and array.get(scr_conf, i) >= min_conf
            valid_total += 1
            if array.get(arr_s_bull, i)
                bull_total += 1
            if array.get(arr_s_bear, i)
                bear_total += 1
            if array.get(arr_s_ee, i)
                ee_total += 1
    
    var tbl_sum = table.new(position.bottom_right, 5, 2,
        bgcolor=color.new(color.black, 10),
        border_width=1,
        border_color=color.new(color.gray, 50))
    
    table.cell(tbl_sum, 0, 0, "TRACKED", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.gray, 40))
    table.cell(tbl_sum, 1, 0, "BULLISH", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.green, 40))
    table.cell(tbl_sum, 2, 0, "BEARISH", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.red, 40))
    table.cell(tbl_sum, 3, 0, "EARLY ENTRY", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.lime, 40))
    table.cell(tbl_sum, 4, 0, "SORT", text_color=color.white, text_size=size.tiny, bgcolor=color.new(color.blue, 40))
    
    table.cell(tbl_sum, 0, 1, str.tostring(valid_total), text_color=color.white, text_size=size.small)
    table.cell(tbl_sum, 1, 1, str.tostring(bull_total), text_color=color.green, text_size=size.small)
    table.cell(tbl_sum, 2, 1, str.tostring(bear_total), text_color=color.red, text_size=size.small)
    table.cell(tbl_sum, 3, 1, str.tostring(ee_total), text_color=color.lime, text_size=size.small)
    table.cell(tbl_sum, 4, 1, sort_opt, text_color=color.blue, text_size=size.tiny)

any_early = false
for i = 0 to N_STOCKS - 1
    if array.get(arr_s_valid, i) and array.get(arr_s_ee, i)
        any_early := true
        break

alertcondition(any_early, title="Screener: Early Entry Found",
    message="Constituent Screener: Early entry signal detected on a monitored stock")

avg_all = array.avg(arr_s_comp)
plot(avg_all, title="Avg Screener Composite", color=color.new(color.blue, 30), linewidth=2)

hline(bull_thr, "Bullish", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(50, "Neutral", color=color.new(color.gray, 50), linestyle=hline.style_dotted)
hline(bear_thr, "Bearish", color=color.new(color.red, 50), linestyle=hline.style_dashed)
